# ===========================================
# STIZ Server 환경 설정
# ===========================================
# 이 파일을 복사하여 .env 파일을 생성하세요
# cp .env.example .env

# 서버 포트
PORT=3000

# Google AI (Gemini + Imagen)
# https://aistudio.google.com/app/apikey 에서 발급
GOOGLE_API_KEY=

# PG 결제 (PortOne / 아임포트)
# https://admin.portone.io 에서 발급
PORTONE_STORE_ID=
PORTONE_CHANNEL_KEY=
PORTONE_API_SECRET=

# JWT 인증 (추후 서버 인증 전환 시 사용)
JWT_SECRET=your-secret-key-change-this
JWT_EXPIRES_IN=7d

# 환경 모드
NODE_ENV=development
