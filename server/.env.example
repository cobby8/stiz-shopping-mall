# ===========================================
# STIZ Server 환경 설정
# ===========================================
# 이 파일을 복사하여 .env 파일을 생성하세요
# cp .env.example .env

# 서버 포트
PORT=4000

# Google AI (Gemini + Imagen)
# https://aistudio.google.com/app/apikey 에서 발급
GOOGLE_API_KEY=

# 토스페이먼츠 PG 결제
# https://developers.tosspayments.com 에서 발급
# 2개 모두 설정하지 않으면 카드 결제 비활성화 (무통장 입금만 표시)
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=

# JWT 인증 (추후 서버 인증 전환 시 사용)
JWT_SECRET=your-secret-key-change-this
JWT_EXPIRES_IN=7d

# SOLAPI 카카오 알림톡 (D-35)
# https://solapi.com 가입 후 콘솔 → API Key 관리에서 발급
# 3개 모두 비어있으면 드라이런 모드 (콘솔 로그만, 실제 발송 X)
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER_PHONE=
# Phase 3에서 카카오 알림톡 활성화 시 추가:
# SOLAPI_KAKAO_PFID=

# 환경 모드
NODE_ENV=development

# 시트 → DB 5분 자동 동기화 (2026-04-29)
# true 시: 서버 시작 후 30초 뒤부터 5분마다 자동으로 시트 → DB sync
# false 시: 비활성 (수동 `node server/data/sync-orders.js --apply`만 가능)
# 운영 권장: 처음에는 false로 시작 → 한 번 수동 검증 후 true로 전환
AUTO_SYNC_ENABLED=false
