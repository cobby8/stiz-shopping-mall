node_modules/
.env
.DS_Store
.gemini/

# 업로드 파일은 Git에 포함하지 않되, 폴더 구조(.gitkeep)는 유지
server/uploads/**
!server/uploads/**/.gitkeep

# 백업 파일
server/data/*.bak
server/data/*.bak-*
server/data/*.pre-*
server/data/backups/
server/data/stiz.db-shm
server/data/stiz.db-wal

# 로그 파일
dev/*.log

# 디자인 원본
dev/design/

# Claude 에이전트 로컬 데이터 (scratchpad/knowledge/worktrees/settings)
# AI 도구 내부 상태라 팀 공유 대상 아님
.claude/
.agents/

# 테스트 스크립트
test-*.js

# K2 챗봇 지식 빌드 결과물 (DB에서 매번 빌드 가능, 개발자별 데이터 상태 상이)
server/data/knowledge/products.json
server/data/knowledge/products.json.tmp

# 견적서 PDF 한글 폰트 (Phase B-1, 2026-04-30)
# 폰트 파일은 저장소 비대화 방지 위해 추적 제외 (README.md 안내 따라 사용자가 다운로드)
server/assets/fonts/*.ttf
server/assets/fonts/*.otf
server/assets/fonts/*.woff
server/assets/fonts/*.woff2
