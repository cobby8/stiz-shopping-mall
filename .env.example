# ============================================================
# STIZ 쇼핑몰 환경변수 예시
# 이 파일을 .env로 복사한 후 실제 값을 입력하세요.
# cp .env.example .env
# ============================================================

# 서버 포트 (기본값: 4000)
PORT=4000

# JWT 비밀키 — 관리자 인증에 사용
JWT_SECRET=your_jwt_secret_here

# ============================================================
# SOLAPI 카카오 알림톡 설정
# https://solapi.com 에서 가입 후 API 키를 발급받으세요.
# 3개 모두 설정하지 않으면 알림톡 대신 콘솔 로그만 출력됩니다.
# ============================================================
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER_PHONE=

# ============================================================
# PortOne(아임포트) PG 결제 설정
# https://admin.portone.io 에서 가입 후 키를 발급받으세요.
# 3개 모두 설정하지 않으면 카드 결제 비활성화 (무통장 입금만 표시)
# ============================================================
PORTONE_MERCHANT_ID=
PORTONE_API_KEY=
PORTONE_API_SECRET=

# ============================================================
# 카카오 로그인 (#14)
# https://developers.kakao.com 에서 앱 생성 후 키를 발급받으세요.
# 2개 모두 설정하지 않으면 카카오 로그인 버튼 비활성화
# ============================================================
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# ============================================================
# 네이버 로그인 (#14)
# https://developers.naver.com 에서 앱 생성 후 키를 발급받으세요.
# 2개 모두 설정하지 않으면 네이버 로그인 버튼 비활성화
# ============================================================
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ============================================================
# 인스타그램 피드 (#17)
# Instagram Basic Display API 토큰
# 설정하지 않으면 Mock 데이터로 피드 표시
# ============================================================
INSTAGRAM_ACCESS_TOKEN=
